#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Automatically update Repowise index on commit
echo "Updating Repowise codebase intelligence index..."
# Skip if repowise CLI unavailable (Python venv may not be set up)
if [ -x ./.aistack/tools/repowise/.venv/bin/repowise ]; then
  ./.aistack/tools/repowise/.venv/bin/repowise update -w --index-only || true
else
  echo "  [skip] repowise CLI not available — install with 'pnpm agentic-tools:setup'"
fi

# Update checksum manifest for changed agentic-tools files
# Handle edge case: first commit has no HEAD~1
PREV_COMMIT=$(git rev-list --max-parents=0 HEAD 2>/dev/null || echo "")
CURRENT_HASH=$(git rev-parse HEAD 2>/dev/null || echo "")
if [ "$PREV_COMMIT" != "$CURRENT_HASH" ] && [ -n "$PREV_COMMIT" ]; then
  CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null | grep -c '\.agentic-tools-mcp/' || true)
  if [ "$CHANGED" -gt 0 ]; then
    echo "Agentic tools changed — updating integrity manifest..."
    node tools/preflight-mcp/index.js --tool mpc_checksum_verify --directory .agentic-tools-mcp/agents 2>/dev/null || true
  fi
fi
