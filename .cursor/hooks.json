{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/alignment-gate.mjs",
        "timeout": 10
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/block-forbidden.mjs",
        "failClosed": true,
        "timeout": 10
      }
    ]
  }
}
