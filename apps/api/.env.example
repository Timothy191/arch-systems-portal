# ── Server ──
# Dev orchestration (scripts/dev.sh) defaults the API to port 3004 so it does
# not collide with the CMS dev server on 3001 or the tools containers on 3001/3003.
NODE_ENV=development
PORT=3004

# ── Supabase ──
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Ollama (AI) ──
OLLAMA_URL=http://localhost:5243

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── Observability ──
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Rate Limiting ──
DISABLE_RATE_LIMIT=false
RATE_LIMIT_IP_WHITELIST=127.0.0.1,::1,::ffff:127.0.0.1
TRUST_PROXY=true

# ── Internal ──
INTERNAL_API_SECRET=

# ── SurrealDB ──
SURREALDB_URL=ws://localhost:8000/rpc
SURREALDB_NS=plantcor
SURREALDB_DB=ai
SURREALDB_USER=root
SURREALDB_PASS=root

# ── AI Behavior Flags ──
AI_GATEWAY_ENABLED=true
AI_FALLBACK_ENABLED=true
AI_RETRY_ENABLED=true
AI_RETRY_ATTEMPTS=2
AI_RETRY_BASE_DELAY_MS=500
AI_REQUEST_TIMEOUT_MS=10000
AI_TELEMETRY_ENABLED=true
AI_CIRCUIT_BREAKER_ENABLED=false
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_CIRCUIT_BREAKER_RECOVERY_MS=30000
AI_STREAMING_ENABLED=false
