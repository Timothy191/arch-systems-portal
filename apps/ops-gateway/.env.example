# NestJS Ops API
OPS_API_URL=http://host.docker.internal:3001/api/ops
OPS_SECRET=change-me-in-production

# Redis (shared with NestJS backend)
REDIS_URL=redis://host.docker.internal:6379

# MCP Server
MCP_PORT=3100

# Polling intervals (ms)
HEALTH_POLL_INTERVAL_MS=15000
METRICS_POLL_INTERVAL_MS=30000

# Incident detection
INCIDENT_THRESHOLD_5XX=5
INCIDENT_WINDOW_MS=60000

# Redis Stream
TRIGGER_STREAM_KEY=ai:triggers:stream
TRIGGER_CONSUMER_GROUP=ops-gateway
TRIGGER_CONSUMER_NAME=gateway-1

# Debug logging
DEBUG=true
