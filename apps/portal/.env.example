# ──────────────────────────────────────────────
# Portal Application — Environment Configuration
# ──────────────────────────────────────────────
# PURPOSE: Portal-specific environment configuration template
# USAGE: Copy this file to .env and fill in actual values
# COMMAND: cp .env.example .env
# WARNING: Never commit the actual .env file with real secrets
# SEE: ../../ENVIRONMENT_FILES_GUIDE.md for detailed usage instructions
# ──────────────────────────────────────────────

# External Tools
N8N_URL=http://localhost:5678
N8N_USER=admin@example.com
N8N_PASSWORD=...

FLOWISE_URL=http://localhost:3001
FLOWISE_USER=admin@example.com
FLOWISE_PASSWORD=...
NEXT_PUBLIC_FUXA_URL=http://localhost:1881

# Supabase Configuration
# For LAN access, set NEXT_PUBLIC_SUPABASE_URL to http://<your_lan_ip>:54321
# Example: NEXT_PUBLIC_SUPABASE_URL=http://192.168.1.100:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only keys
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_ANON_KEY=your_anon_key

# Read replica (optional — falls back to NEXT_PUBLIC_SUPABASE_URL when not set)
# SUPABASE_READ_REPLICA_URL=http://127.0.0.1:54322

# Ollama — local LLM for all AI features
# Default: http://localhost:5243, works when Ollama runs directly on the host
# Override: OLLAMA_URL=http://localhost:5243 if Ollama is port-mapped elsewhere
OLLAMA_URL=http://localhost:5243

# Embedding model for AI memory system (requires the model to be pulled in Ollama)
# Default: nomic-embed-text:latest (free, 768-dim)
# OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Redis — used for rate limiting, department slug cache, and session data
# Default connects to local Redis; override for remote/production instances
REDIS_URL=redis://localhost:6379

# Backend NestJS API
# Dev orchestration starts the API on port 3004 by default so it does not clash
# with the CMS (3001) or tools containers (3001/3003).
API_BASE_URL=http://localhost:3004/api
NEXT_PUBLIC_API_URL=http://localhost:3004/api

# Sentry — error monitoring
# Server-side (instrumentation.ts): required for Server Actions, API routes, background jobs
SENTRY_DSN=
# Client-side (sentry.client.config.ts): required for browser error capture
NEXT_PUBLIC_SENTRY_DSN=
# Set by CI/Vercel automatically; override manually if needed
# SENTRY_ORG=your_org
# SENTRY_PROJECT=your_project

# Hardware access-control scanner (optional — defaults shown)
# Comma-separated list of allowed x-scanner-source header values
# ALLOWED_SCANNER_SOURCES=C66-HARDWARE,C66-SCANNER,GATE-TERMINAL

# OpenTelemetry (optional — only activates when OTEL_EXPORTER_OTLP_ENDPOINT is set)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=arch-portal
