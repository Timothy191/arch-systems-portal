# ─── apps/portal — .env.example ─────────────────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local to git.

# ── Next.js ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Local dev (pnpm supabase start):
#   URL:      http://localhost:54321
#   anon key: printed by `supabase status`
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ── Redis ─────────────────────────────────────────────────────────────────────
# Must match the Redis container exposed in docker-compose.yml
REDIS_URL=redis://localhost:6379

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Arch Systems"

# ── External Tools ───────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_USER=admin@example.com
N8N_PASSWORD=...
FLOWISE_URL=http://localhost:3001
FLOWISE_PASSWORD=...
NEXT_PUBLIC_FUXA_URL=http://localhost:1881

# ── Sentry (optional) ───────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Hardware Scanner (optional) ──────────────────────────────────────────────
ALLOWED_SCANNER_SOURCES=C66-HARDWARE,C66-SCANNER,GATE-TERMINAL

# ── OAuth (optional) ─────────────────────────────────────────────────────────
# Enable Google / Azure / GitHub under Supabase Auth -> Providers.
# Redirect URL to allowlist: {NEXT_PUBLIC_APP_URL}/auth/callback

# ═════════════════════════════════════════════════════════════════════════════
# AI / LLM Providers — Agentic Completion Endpoint & API Key Placeholders
# ═════════════════════════════════════════════════════════════════════════════
#
# Provider Router commands:
#   pnpm provider:route              # Status overview
#   pnpm provider:route --check      # Probe all providers/keys
#   pnpm provider:route --execute    # Route prompt through best available
#   pnpm provider:route --reset      # Clear all cooldowns
#
# AI Gateway backend strategy (in apps/portal/src/lib/ai/gateway.ts):
#   AI_BACKEND_STRATEGY=ollama    # ollama | gemini | router | omni
#
# Display metadata (shown to users, independent of backend):
#   AI_DISPLAY_PROVIDER=google
#   AI_DISPLAY_MODEL=gemini-2.0-flash-exp
# ═════════════════════════════════════════════════════════════════════════════

# ── 1. Groq (Fastest — permanent free tier, no CC needed) ──────────────────
#    Sign up: https://console.groq.com/keys
#    Endpoint: https://api.groq.com/openai/v1/chat/completions
#    Auth: Authorization: Bearer gsk_xxxxx
#    Free models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
# GROQ_API_KEY=gsk_xxxxx
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_FREE_MODEL=llama-3.3-70b-versatile

# ── 2. Cerebras (High throughput — ~1M tokens/day free) ────────────────────
#    Sign up: https://inference-docs.cerebras.ai/
#    Endpoint: https://api.cerebras.ai/v1/chat/completions
#    Free tier: ~1M tokens/day, no CC required.
#    Best for: agentic workflows, high-throughput batch processing.
# CEREBRAS_API_KEY=sk-xxxxx
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# CEREBRAS_FREE_MODEL=llama-3.3-70b

# ── 3. Google Gemini (Generous free tier — multimodal) ─────────────────────
#    Get key: https://aistudio.google.com/apikey
#    Endpoint: https://generativelanguage.googleapis.com/v1/models/{model}:generateContent?key=AIza...
#    Auth: key as query param (?key=AIza...)
#    Free models: gemini-2.0-flash-exp, gemini-1.5-flash
#    NOTE: NOT OpenAI-compatible (native API).
# GEMINI_API_KEY=AIzaSy...
# GEMINI_FREE_MODEL=gemini-2.0-flash-exp

# ── 4. Mistral AI (High volume — ~1B tokens/month experimental) ────────────
#    Sign up: https://console.mistral.ai/
#    Endpoint: https://api.mistral.ai/v1/chat/completions
#    Free experimental tier: high monthly quotas, no CC.
#    OpenAI-compatible. Best for code generation.
# MISTRAL_API_KEY=sk-xxxxx
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_FREE_MODEL=mistral-small-latest

# ── 5. OpenRouter (Key pool — multi-model aggregator) ──────────────────────
#    Sign up: https://openrouter.ai/keys
#    Endpoint: https://openrouter.ai/api/v1/chat/completions
#    Key pool: comma-separated, auto-rotated on 429/401.
#    Free models: cohere/north-mini-code:free, google/gemini-2.0-flash-exp:free
#    OpenAI-compatible. Best for model variety + failover.
#    NOTE: Requires HTTP-Referer and X-Title headers.
# OPENROUTER_KEY_POOL=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_FREE_MODEL=cohere/north-mini-code:free
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=Arch Systems

# ── 6. DeepSeek (Coding — ~500 req/day free tier) ──────────────────────────
#    Sign up: https://platform.deepseek.com/
#    Endpoint: https://api.deepseek.com/v1/chat/completions
#    Free tier: rate-limited. OpenAI-compatible.
#    Best for: coding + reasoning.
# DEEPSEEK_API_KEY=sk-xxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_FREE_MODEL=deepseek-chat

# ── 7. Ollama (Local or cloud — native API) ────────────────────────────────
#    Local: http://localhost:11434 (no API key required)
#    Cloud: https://ollama.com (API key from https://ollama.com/settings/keys)
#    Endpoint: {base_url}/api/chat (native) or {base_url}/v1/chat/completions (OpenAI)
#    Local free; cloud requires account + API key.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_API_KEY=
# OLLAMA_DEFAULT_MODEL=gemma4:latest

# ── 8. Hugging Face (Thousands of open models — free serverless) ──────────
#    Get token: https://huggingface.co/settings/tokens
#    Endpoint: https://api-inference.huggingface.co/models/{model}/v1/chat/completions
#    Free: ~100 req/hour, no CC needed. Thousands of models.
#    OpenAI-compatible via TGI endpoint.
# HF_API_KEY=hf_xxxxx
# HF_BASE_URL=https://api-inference.huggingface.co
# HF_FREE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ── 9. OpenCode (⚠️ endpoint may be unstable) ──────────────────────────────
#    Endpoint: https://opencode.ai/zen/go/v1/chat/completions
# OPENCODE_API_KEY=sk-xxxxx
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
# OPENCODE_MODEL=deepseek-v4-flash

# ── 10. AIHubMix (OpenAI-compatible — free models available) ───────────────
#    Endpoint: https://api.aihubmix.com/v1/chat/completions
# AIHUBMIX_API_KEY=sk-xxxxx
# AIHUBMIX_BASE_URL=https://api.aihubmix.com/v1
# AIHUBMIX_MODEL=coding-glm-4.6-free

# ── 11. Venice.ai (Privacy-focused — free tier) ────────────────────────────
#    Endpoint: https://api.venice.ai/api/v1/chat/completions
# VENICE_API_KEY=sk-xxxxx
# VENICE_BASE_URL=https://api.venice.ai/api/v1
# VENICE_MODEL=kimi-k3

# ── 12. Cohere (RAG/embeddings — free trial) ───────────────────────────────
#    Sign up: https://dashboard.cohere.com/ (free trial key)
#    Endpoint: https://api.cohere.ai/v1/chat (NOT OpenAI-compatible)
#    Trial tier: rate-limited. Best for RAG, embeddings, classification.
# COHERE_API_KEY=xxxxx
# COHERE_BASE_URL=https://api.cohere.ai/v1
# COHERE_MODEL=command-r

# ── 13. Anthropic / Claude (Paid — best reasoning) ─────────────────────────
#    Sign up: https://console.anthropic.com/ (requires credit card)
#    Endpoint: https://api.anthropic.com/v1/messages (NOT OpenAI-compatible)
#    Requires: x-api-key header + anthropic-version header.
#    Paid only. Best for complex reasoning, coding, analysis.
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── 14. Perplexity (Paid — web-search augmented) ───────────────────────────
#    Sign up: https://docs.perplexity.ai/ (requires credit card)
#    Endpoint: https://api.perplexity.ai/chat/completions
#    OpenAI-compatible. Paid only.
# PERPLEXITY_API_KEY=pplx-xxxxx
# PERPLEXITY_BASE_URL=https://api.perplexity.ai
# PERPLEXITY_MODEL=sonar-pro

# ── 15. Together AI (Paid — best model selection) ──────────────────────────
#    Sign up: https://www.together.ai/ (requires credit card + $5 min)
#    Endpoint: https://api.together.xyz/v1/chat/completions
#    OpenAI-compatible. Paid only.
# TOGETHER_API_KEY=xxxxx
# TOGETHER_BASE_URL=https://api.together.xyz/v1
# TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ── AI Gateway display/backend split ────────────────────────────────────────
# Show Gemini in UI/logs while routing inference elsewhere:
# AI_DISPLAY_PROVIDER=google
# AI_DISPLAY_MODEL=gemini-2.0-flash-exp
# AI_BACKEND_STRATEGY=ollama   # ollama | gemini | router | omni

# ── Inference.net Catalyst (optional — gateway + tracing) ───────────────────
# Dashboard: https://inference.net — CLI: `inf auth login` then set keys below.
# Never commit real keys. Prefer apps/portal/.env.local (gitignored).
# INFERENCE_GATEWAY_ENABLED=true
# INFERENCE_API_KEY=sk-inference-…
# INFERENCE_TASK_ID=arch-portal
# INFERENCE_ENVIRONMENT=development
# CATALYST_OTLP_TOKEN=sk-inference-…   # usually same as INFERENCE_API_KEY
# CATALYST_OTLP_ENDPOINT=https://telemetry.inference.net
# CATALYST_SERVICE_NAME=portal-ui

# ── Provider Router global settings ─────────────────────────────────────────
# Cooldown in seconds before retrying an exhausted provider/key
# PROVIDER_COOLDOWN_SEC=300
