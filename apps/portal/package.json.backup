{
  "name": "portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests --runInBand --forceExit",
    "prebuild": "rm -rf .next"
  },
  "dependencies": {
    "@repo/errors": "workspace:*",
    "@repo/redis": "workspace:*",
    "@repo/supabase": "workspace:*",
    "@repo/theme": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/utils": "workspace:*",
    "framer-motion": "^12.4.0",
    "lucide-react": "^0.469.0",
    "next": "15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.1",
    "zod": "^3.24.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
