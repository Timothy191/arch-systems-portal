# ─────────────────────────────────────────────────────────────────
# Arch-Systems Portal — Production Environment Template
# ─────────────────────────────────────────────────────────────────
# PURPOSE: Production deployment environment configuration template
# USAGE: Copy to .env and fill in all required values before deploying
# WARNING: NEVER commit this file with real secrets
# SEE: ../../ENVIRONMENT_FILES_GUIDE.md for detailed production deployment
# ─────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────
# Replace <server-ip> with the on-premises server's LAN IP address.
NEXT_PUBLIC_SUPABASE_URL=http://<server-ip>:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_URL=http://<server-ip>:54321
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_KEY=<your-service-role-key>

# Read replica (optional — omit if not running docker-compose.replica.yml)
SUPABASE_READ_REPLICA_URL=http://<server-ip>:54322

# ── AI functionality has been removed ─────────────────────────────────

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://:...@localhost:6379
# Must match REDIS_PASSWORD in docker-compose.production.yml
REDIS_PASSWORD=...

# ── External Tools ────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_USER=admin@example.com
N8N_PASSWORD=...
N8N_ENCRYPTION_KEY=...

FLOWISE_URL=http://localhost:3001
FLOWISE_USER=admin@example.com
FLOWISE_PASSWORD=...
FLOWISE_SECRETKEY_OVERWRITE=...

# ── Monitoring ────────────────────────────────────────────────────
SENTRY_DSN=<your-sentry-dsn>

# ── Langfuse (LLM Observability) ─────────────────────────────────
LANGFUSE_URL=http://localhost:3002

# ── Deployment Notifications (optional) ──────────────────────────
# If set, deploy-production.sh will POST to this URL on successful deploy.
# Create an n8n webhook trigger and paste the URL here.
DEPLOY_WEBHOOK_URL=http://localhost:5678/webhook/<your-webhook-id>

# ── Next.js ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
NEXTAUTH_URL=http://<server-ip>:3000
NEXTAUTH_SECRET=...
