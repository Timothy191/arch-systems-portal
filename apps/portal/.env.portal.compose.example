# Docker Compose environment file for the Portal stack
# Copy this to apps/portal/.env.portal.compose and fill in real values.
#
# Key fix: uses host.docker.internal instead of 127.0.0.1 so the container
# resolves services on the Docker host, not itself.

# ── Build-time vars (injected as docker build args) ──
NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_HIGHLIGHT_PROJECT_ID=0  # set to 0 if not using Highlight yet
NEXT_PUBLIC_FUXA_URL=http://host.docker.internal:1881
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_VERCEL_ENV=production

# ── Runtime vars — server-side API calls resolve inside the container ──
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_SERVICE_KEY=your_service_key_here
SUPABASE_ANON_KEY=your_anon_key_here
REDIS_URL=redis://plantcor-redis:6379
REDIS_PASSWORD=...
SENTRY_DSN=your_sentry_dsn_here
OPENAI_API_KEY=your_openai_key_here
