{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "secretlint",
    "@modelcontextprotocol/sdk",
    "@secretlint/secretlint-rule-preset-recommend",
    "preflight",
    "@repo/eslint-config",
    "@typescript-eslint/parser",
    "eslint-import-resolver-typescript",
    "@eslint/js",
    "globals",
    "lint-staged",
    "typescript-eslint"
  ],
  "ignoreBinaries": ["python3", "psql"],
  "ignore": ["**/jest.config.*", "**/postcss.config.*", "pnpm-workspace.yaml"],
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{ts,js}", ".eslintrc.{js,cjs}"],
      "project": ["scripts/**/*.{ts,js}"]
    },
    "apps/portal": {
      "entry": [
        "app/**/layout.tsx",
        "app/**/page.tsx",
        "app/**/route.ts",
        "proxy.ts",
        "plugins/rust-telemetry-engine/index.tsx",
        ".eslintrc.{js,cjs}"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "features/**/*.{ts,tsx}",
        "hooks/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "plugins/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": ["autoprefixer", "postcss", "tailwindcss"],
      "ignore": [
        "lib/observability/logger.ts",
        "lib/api/schemas.ts",
        "lib/observability/metrics.ts",
        "components/ui/PrecisionInput.tsx",
        "features/analytics/components/ReportTemplate.tsx",
        "lib/ai/tool-dispatch.ts",
        "lib/errors/error-classes.ts"
      ]
    },
    "packages/theme": {
      "entry": ["src/tokens/*.ts", "src/react/*.tsx", ".eslintrc.{js,cjs}"],
      "project": ["src/**/*.{ts,tsx,css}"],
      "ignore": ["src/tokens/colors.ts", "src/tokens/motion.ts"]
    },
    "packages/database": {
      "entry": [".eslintrc.{js,cjs}"],
      "project": ["migrations/**/*.sql"],
      "ignore": ["supabase/migrations/**"]
    },
    "packages/eslint-config": {
      "entry": ["*.js"],
      "project": ["*.js"]
    },
    "packages/supabase": {
      "entry": [
        "src/index.ts",
        "src/server.ts",
        "src/client.ts",
        "src/middleware.ts",
        "src/service-role.ts",
        ".eslintrc.{js,cjs}"
      ],
      "project": ["src/**/*.ts"],
      "ignore": ["src/database.types.ts"]
    },
    "packages/errors": {
      "entry": ["src/index.ts", ".eslintrc.{js,cjs}"],
      "project": ["src/**/*.ts"]
    },
    "packages/types": {
      "entry": ["src/index.ts", ".eslintrc.{js,cjs}"],
      "project": ["src/**/*.ts"]
    },
    "packages/typescript-config": {
      "entry": ["*.json"],
      "project": ["*.json"],
      "ignoreDependencies": ["next"]
    },
    "packages/utils": {
      "entry": ["src/index.ts", ".eslintrc.{js,cjs}"],
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/**/*.tsx", ".eslintrc.{js,cjs}"],
      "project": ["src/**/*.{ts,tsx,css}"],
      "ignore": [
        "src/components/edges/FlowEdge.tsx",
        "src/components/nodes/PluginNode.tsx",
        "src/components/nodes/TriggerNode.tsx",
        "src/components/WorkflowBuilder.tsx"
      ]
    },
    "packages/redis": {
      "entry": ["src/index.ts", ".eslintrc.{js,cjs}"],
      "project": ["src/**/*.ts"]
    },
    "packages/rate-limiter": {
      "entry": ["src/index.ts", ".eslintrc.{js,cjs}"],
      "project": ["src/**/*.ts"]
    },
    "packages/eval": {
      "entry": ["tests/**/*.py"],
      "project": ["**/*.{py,toml}"]
    }
  },
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "unlisted": "warn",
    "binaries": "warn",
    "exports": "error",
    "nsExports": "warn",
    "types": "warn",
    "nsTypes": "warn",
    "duplicates": "warn",
    "unresolved": "warn"
  }
}
