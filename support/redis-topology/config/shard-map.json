{
  "version": "1.0",
  "namespaces": {
    "default": {
      "strategy": "consistent-hashing",
      "nodes": ["redis-node-1:6379", "redis-node-2:6379", "redis-node-3:6379"]
    },
    "turbo": {
      "strategy": "hash-slot",
      "nodes": ["redis-node-1:6379", "redis-node-2:6379", "redis-node-3:6379"]
    },
    "telemetry": {
      "strategy": "single",
      "nodes": ["redis-node-1:6379"]
    }
  }
}
