# Arch-Systems — Docker Compose Tools Stack Environment Template
# ──────────────────────────────────────────────
# PURPOSE: Secrets and configuration for docker-compose.tools.yml services
#            (n8n, langfuse, clickhouse, prometheus, fuxa, etc.)
# USAGE: Copy this file to .env.tools and fill in actual values.
# COMMAND: cp .env.tools.example .env.tools
# WARNING: Never commit .env.tools or any .env.*.local files.
# ──────────────────────────────────────────────

# Tool stack admin credentials
TOOL_ADMIN_EMAIL=admin@example.com
TOOL_ADMIN_PASSWORD=change-me-now

# n8n encryption key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# Langfuse database
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=change-me-now
LANGFUSE_DB_NAME=langfuse

# ClickHouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me-now

# Langfuse secrets (generate with: openssl rand -hex 32)
TOOL_NEXTAUTH_SECRET=change-me-to-a-32-byte-hex-string
TOOL_SALT=change-me-to-a-32-byte-hex-string
TOOL_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string
