# ──────────────────────────────────────────────
# Arch-Systems — Root Environment Configuration Template
# ──────────────────────────────────────────────
# PURPOSE: Workspace-level secrets and external tool credentials.
# USAGE: Copy this file to .env and fill in actual values.
# COMMAND: cp .env.example .env
# WARNING: Never commit .env or any .env.*.local files.
# ──────────────────────────────────────────────

# n8n workflow orchestration (used by tools/n8n-mcp)
N8N_URL=http://localhost:5678
N8N_EMAIL=your-n8n-email@example.com
N8N_PASSWORD=your-n8n-password

# GitHub integration (used by github-official MCP server)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Gemini / Memex analytical processing (used by tools/memex)
GEMINI_API_KEY=your-gemini-api-key

# Redis (optional override; apps also read their own .env files)
REDIS_URL=redis://localhost:6379

# Neo4j for Memex developer memory (default local container)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memex-local

# SurrealDB for AI memory and agentic content
SURREALDB_URL=ws://localhost:8000/rpc
SURREALDB_NS=plantcor
SURREALDB_DB=ai
SURREALDB_USER=root
SURREALDB_PASS=root
