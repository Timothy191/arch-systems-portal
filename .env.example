# ─── Arch Systems — Root .env.example ───────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── Redis ────────────────────────────────────────────────────────────────────
# Local dev default — Docker Compose exposes Redis on 6379
REDIS_URL=redis://localhost:6379

# ── Supabase (local dev — run: pnpm supabase start) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ── Optional: GitHub integration ─────────────────────────────────────────────
# GITHUB_PERSONAL_ACCESS_TOKEN=

# ═════════════════════════════════════════════════════════════════════════════
# AI / LLM Providers — Provider Router (pnpm provider:route)
# ═════════════════════════════════════════════════════════════════════════════
#
# The router auto-cycles providers in priority order:
#   Groq (fastest) → Cerebras → Gemini → Mistral → OpenRouter → DeepSeek →
#   HuggingFace → OpenCode → AIHubMix → Venice → Cohere → Anthropic →
#   Perplexity → Together
#
# Key types:
#   - Pool: OPENROUTER_KEY_POOL=sk-key1,sk-key2,... (rotates on 429/401)
#   - Single: PROVIDER_API_KEY=sk-xxxxx (one key per provider)
#
# Provider Router commands:
#   pnpm provider:route              # Status overview
#   pnpm provider:route --check      # Probe all providers/keys
#   pnpm provider:route --execute    # Route prompt through best available
#   pnpm provider:route --reset      # Clear all cooldowns
# ═════════════════════════════════════════════════════════════════════════════

# ── 1. Groq (Fastest — permanent free tier, no CC needed) ──────────────────
#    Sign up: https://console.groq.com/keys
#    Free models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
#    ~30 req/min on free tier. OpenAI-compatible.
# GROQ_API_KEY=gsk_xxxxx
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_FREE_MODEL=llama-3.3-70b-versatile

# ── 2. Cerebras (High throughput — ~1M tokens/day free) ────────────────────
#    Sign up: https://inference-docs.cerebras.ai/
#    Free tier: ~1M tokens/day, very fast training/inference.
#    OpenAI-compatible. Best for agentic workflows.
# CEREBRAS_API_KEY=sk-xxxxx
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# CEREBRAS_FREE_MODEL=llama-3.3-70b

# ── 3. Google Gemini (Generous free tier — multimodal) ─────────────────────
#    Get key: https://aistudio.google.com/apikey
#    Free: gemini-2.0-flash-exp, gemini-1.5-flash
#    ~60 req/min. NOT OpenAI-compatible (native API).
#    Auth: key as query param (?key=...)
# GEMINI_API_KEY=AIzaSy...
# GEMINI_FREE_MODEL=gemini-2.0-flash-exp

# ── 4. Mistral AI (High volume — ~1B tokens/month experimental) ────────────
#    Sign up: https://console.mistral.ai/
#    Free experimental tier: high monthly quotas.
#    OpenAI-compatible. Best for code generation.
# MISTRAL_API_KEY=sk-xxxxx
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_FREE_MODEL=mistral-small-latest

# ── 5. OpenRouter (Key pool — multi-model aggregator) ──────────────────────
#    Sign up: https://openrouter.ai/keys
#    Key pool: comma-separated, auto-rotated on 429.
#    Free models: cohere/north-mini-code:free, google/gemini-2.0-flash-exp:free
#    OpenAI-compatible. Best for model variety + failover.
# OPENROUTER_KEY_POOL=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_FREE_MODEL=cohere/north-mini-code:free
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=Arch Systems

# ── 6. DeepSeek (Coding — ~500 req/day free tier) ──────────────────────────
#    Sign up: https://platform.deepseek.com/
#    Free tier: rate-limited. Best for coding + reasoning.
#    OpenAI-compatible.
# DEEPSEEK_API_KEY=sk-xxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_FREE_MODEL=deepseek-chat

# ── 7. Ollama (Local or ollama.com cloud — native API) ─────────────────────
#    Local: http://localhost:11434 (no API key)
#    Cloud: https://ollama.com + API key from https://ollama.com/settings/keys
# OLLAMA_URL=https://ollama.com
# OLLAMA_API_KEY=your-ollama-cloud-key
# OLLAMA_DEFAULT_MODEL=gemma4:latest

# ── AI gateway (display vs backend split) ───────────────────────────────────
# Show Gemini in UI/logs while routing inference elsewhere:
# AI_DISPLAY_PROVIDER=google
# AI_DISPLAY_MODEL=gemini-2.0-flash-exp
# AI_BACKEND_STRATEGY=ollama   # ollama | gemini | router

# ── 8. Hugging Face (Thousands of open models — free serverless) ──────────
#    Get token: https://huggingface.co/settings/tokens
#    Free: ~100 req/hour, no CC needed. Thousands of models.
#    Supports both native HF API and OpenAI-compatible (TGI).
# HF_API_KEY=hf_xxxxx
# HF_BASE_URL=https://api-inference.huggingface.co
# HF_FREE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ── 8. OpenCode (⚠️ endpoint was returning 500) ────────────────────────────
# OPENCODE_API_KEY=sk-xxxxx
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
# OPENCODE_MODEL=deepseek-v4-flash

# ── 9. AIHubMix (OpenAI-compatible — free models available) ────────────────
# AIHUBMIX_API_KEY=sk-xxxxx
# AIHUBMIX_BASE_URL=https://api.aihubmix.com/v1
# AIHUBMIX_MODEL=coding-glm-4.6-free

# ── 10. Venice.ai (Privacy-focused — free tier available) ──────────────────
# VENICE_API_KEY=sk-xxxxx
# VENICE_BASE_URL=https://api.venice.ai/api/v1
# VENICE_MODEL=kimi-k3

# ── 11. Cohere (RAG/embeddings — free trial tier) ──────────────────────────
# Sign up: https://dashboard.cohere.com/
# Trial tier: rate-limited. Best for RAG, embeddings, classification.
# NOT OpenAI-compatible (native: /chat, /generate, /embed, /rerank).
# COHERE_API_KEY=xxxxx
# COHERE_BASE_URL=https://api.cohere.ai/v1
# COHERE_MODEL=command-r

# ── 12. Anthropic / Claude (Paid — best reasoning) ──────────────────────────
# Sign up: https://console.anthropic.com/ (requires credit card)
# Paid only. Best for complex reasoning, coding, analysis.
# NOT OpenAI-compatible (native: POST /v1/messages).
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── 13. Perplexity (Paid — web-search augmented generation) ────────────────
# Sign up: https://docs.perplexity.ai/ (requires credit card)
# Paid only. Best for search-augmented generation.
# OpenAI-compatible.
# PERPLEXITY_API_KEY=pplx-xxxxx
# PERPLEXITY_BASE_URL=https://api.perplexity.ai
# PERPLEXITY_MODEL=sonar-pro

# ── 14. Together AI (Paid — best model selection) ─────────────────────────
# Sign up: https://www.together.ai/
# Paid only. Best model selection for production inference.
# OpenAI-compatible.
# TOGETHER_API_KEY=xxxxx
# TOGETHER_BASE_URL=https://api.together.xyz/v1
# TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ── Provider Router settings ─────────────────────────────────────────────────
# Cooldown in seconds before retrying an exhausted provider/key (default: 300 = 5 min)
# PROVIDER_COOLDOWN_SEC=300
