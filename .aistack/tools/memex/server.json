{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.stifler7/memex",
  "description": "Temporal knowledge graph of your codebase (Graphiti + Neo4j), served to AI agents via MCP.",
  "version": "0.6.0",
  "repository": {
    "url": "https://github.com/STiFLeR7/memex",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "stifler-memex-mcp",
      "version": "0.6.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "serve"
        },
        {
          "type": "named",
          "name": "--repo",
          "value": "."
        }
      ],
      "environmentVariables": [
        {
          "name": "NEO4J_URI",
          "description": "Bolt URI of your Neo4j instance",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "NEO4J_USER",
          "description": "Neo4j username",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "NEO4J_PASSWORD",
          "description": "Neo4j password",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "GEMINI_API_KEY",
          "description": "Google Gemini API key for entity extraction",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    },
    {
      "registryType": "pypi",
      "identifier": "memex-mcp",
      "version": "0.6.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "uvx",
      "packageArguments": [
        {
          "type": "positional",
          "value": "serve"
        },
        {
          "type": "named",
          "name": "--repo",
          "value": "."
        }
      ],
      "environmentVariables": [
        {
          "name": "NEO4J_URI",
          "description": "Bolt URI of your Neo4j instance",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "NEO4J_USER",
          "description": "Neo4j username",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "NEO4J_PASSWORD",
          "description": "Neo4j password",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "GEMINI_API_KEY",
          "description": "Google Gemini API key for entity extraction",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
