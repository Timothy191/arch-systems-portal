{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.json",
    "pnpm-workspace.yaml",
    ".npmrc"
  ],
  "globalEnv": [
    "NODE_ENV",
    "VERCEL_ENV",
    "CI",
    "TURBO_TELEMETRY_DISABLED",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "INNGEST_EVENT_KEY",
    "NOVU_API_KEY",
    "OTEL_SERVICE_NAME",
    "PORTAL_VERSION",
    "RATE_LIMIT_IP_WHITELIST",
    "ENABLE_LOAD_ADAPTIVE_TEST",
    "DISABLE_RATE_LIMIT"
  ],
  "tasks": {
    "codegen": {
      "inputs": ["src/css/variables.css", "scripts/generate-tokens.mjs"],
      "outputs": ["src/tokens/generated.ts"],
      "cache": true
    },
    "lint:tokens": {
      "inputs": ["src/css/variables.css", "src/tailwind/preset.ts", "scripts/validate-tokens.mjs"],
      "cache": true
    },
    "lint:css": {
      "inputs": ["src/**/*.css", ".stylelintrc.*"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "^codegen"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.test.ts",
        "!**/*.test.tsx",
        "!**/*.spec.ts",
        "!**/*.spec.tsx",
        "!**/__tests__/**",
        "!**/*.stories.tsx"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "cache": true
    },
    "db:pull": {
      "outputs": ["packages/supabase/migrations/**"],
      "cache": false
    },
    "type-check": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.ts", "!**/*.test.tsx", "!**/*.md", "!**/*.stories.*"],
      "outputs": ["**/*.tsbuildinfo"],
      "cache": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.ts", "!**/*.test.tsx", "!**/*.md", "!**/*.stories.*", "!**/__fixtures__/**"],
      "outputs": ["node_modules/.cache/.eslintcache"],
      "cache": true
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "vitest.config.*", "playwright.config.*", "!**/*.md", "!**/*.stories.*"],
      "outputs": ["coverage/**/*"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
