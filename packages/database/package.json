{
  "name": "@repo/database",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "kysely": "^0.29.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./query-builder": "./src/query-builder.ts",
    "./migrations/*": "./migrations/*"
  },
  "private": true,
  "scripts": {
    "clean": "rm -rf .turbo",
    "lint": "echo 'No lintable files in @repo/database'",
    "test:migration-rollback": "node tests/migration-rollback-safety.mjs",
    "test:security:p0-signup-role": "PGPASSWORD=${DB_PASSWORD:-postgres} psql -h ${DB_HOST:-localhost} -p ${DB_PORT:-5432} -U ${DB_USER:-postgres} -d ${DB_NAME:-coal_mine} -v ON_ERROR_STOP=1 -f tests/p0_signup_role_self_elevation.sql"
  }
}
