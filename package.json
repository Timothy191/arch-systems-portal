{
  "name": "arch-systems",
  "version": "1.5.1",
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.60.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "eslint": "^8.57.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^5.45.0",
    "lint-staged": "^17.0.7",
    "markdownlint-cli": "^0.49.0",
    "preflight": "^0.2.0",
    "prettier": "^3.4.2",
    "secretlint": "^13.0.2",
    "supabase": "^2.98.2",
    "syncpack": "^13.0.4",
    "turbo": "^2.10.2",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "overrides": {
    "handlebars": ">=4.7.9",
    "brace-expansion": ">=2.0.2",
    "minimatch": ">=9.0.7",
    "braces": ">=3.0.3",
    "glob": ">=10.5.0",
    "serialize-javascript": ">=7.0.3",
    "kysely": ">=0.28.17",
    "tmp": ">=0.2.6",
    "uuid": ">=11.1.1",
    "smol-toml": ">=1.3.1",
    "esbuild": ">=0.25.0",
    "@babel/runtime": ">=7.26.10",
    "js-yaml@^3.0.0": ">=3.14.2",
    "js-yaml@^4.0.0": ">=4.1.1"
  },
  "packageManager": "pnpm@9.15.9",
  "private": true,
  "scripts": {
    "agentic-tools": "pnpm --filter @repo/agentic-tools-mcp start",
    "agentic-tools:daemon": "pnpm --filter @repo/agentic-tools-mcp daemon",
    "agentic-tools:setup": "cp -n .env.example .env 2>/dev/null || true && echo 'Fill .env with real secrets'",
    "analyze": "ANALYZE=true pnpm --filter portal build",
    "audit:rls": "node tools/audit-rls.cjs",
    "build": "turbo run build",
    "checksum:verify": "node tools/preflight-mcp/index.js --tool mpc_checksum_verify --directory .agentic-tools-mcp/memories",
    "cleanup": "bash tools/cleanup.sh",
    "commitlint": "commitlint --edit",
    "db:docs": "bash scripts/generate-db-docs.sh",
    "deploy": "bash scripts/deploy.sh",
    "deploy:dev": "bash scripts/deploy-dev.sh",
    "deploy:local": "bash scripts/deploy.sh local",
    "deploy:production": "bash scripts/deploy.sh production",
    "deploy:rollback": "bash scripts/deploy.sh production --rollback",
    "deploy:staging": "bash scripts/deploy.sh staging",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "deps:lint": "syncpack lint",
    "dev": "bash scripts/dev.sh",
    "ensure-reachability": "python3 scripts/ensure_reachability.py",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "fresh-start": "bash scripts/deploy.sh local --clean",
    "knip": "knip --no-config-hints",
    "knip:fix": "knip --fix --no-config-hints",
    "lint": "turbo run lint",
    "lint:root": "eslint . --max-warnings 0 --ignore-pattern apps --ignore-pattern packages --ignore-pattern temp --ignore-pattern .aistack --no-error-on-unmatched-pattern",
    "mcp:check": "node tools/preflight-mcp/index.js",
    "md:fix": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore '**/node_modules' --ignore '**/.next' --ignore '**/dist'",
    "md:lint": "markdownlint \"**/*.md\" --ignore node_modules --ignore '**/node_modules' --ignore '**/.next' --ignore '**/dist'",
    "merge:skills": "bash .agentic-tools-mcp/scripts/merge_skills.sh",
    "monitor": "bash scripts/monitor-hud.sh",
    "monitor:grafana": "docker compose -f docker-compose.monitoring.yml up -d",
    "monitor:grafana-stop": "docker compose -f docker-compose.monitoring.yml down",
    "mpc:build": "node tools/preflight-mcp/index.js --tool mpc_parallel_build",
    "mpc:fft": "node tools/preflight-mcp/index.js --tool mpc_fft_analyze",
    "mpc:graph": "node tools/preflight-mcp/index.js --tool mpc_dependency_graph",
    "mpc:quality": "node tools/preflight-mcp/index.js --tool mpc_full_quality_gate",
    "policy:check": "node tools/policy-compiler.cjs --check",
    "policy:gen": "node tools/policy-compiler.cjs",
    "prepare": "husky",
    "quality": "turbo run lint type-check test lint:tokens lint:css && pnpm lint:root && pnpm format:check && pnpm deps:lint && pnpm knip",
    "shutdown": "bash scripts/shutdown.sh",
    "syncpack": "syncpack lint",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "type-check": "turbo run type-check",
    "ui": "pnpm --filter @repo/ui ui"
  },
  "type": "module",
  "volta": {
    "node": "24.15.0",
    "pnpm": "9.15.9"
  }
}
