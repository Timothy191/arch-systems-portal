{
  "name": "arch-systems",
  "version": "1.5.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "24.15.0",
    "pnpm": "9.15.9"
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:quick": "bash scripts/dev.sh --quick",
    "dev:no-infra": "bash scripts/dev.sh --no-infra",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "deploy:dev": "bash deploy-dev-mode.sh",
    "deploy:local": "bash scripts/dev.sh",
    "shutdown": "bash scripts/shutdown.sh",
    "quality": "turbo run lint type-check test --concurrency=4 && pnpm format:check",
    "ai": "bash scripts/ai.sh status",
    "ai:init": "bash scripts/ai.sh init",
    "ai:onboard": "bash scripts/ai.sh onboard",
    "ai:check": "bash scripts/ai.sh check",
    "ai:fix": "bash scripts/ai.sh fix",
    "audit:rls": "node tools/audit-rls.cjs",
    "clean": "turbo run clean && find . -name '.next' -type d -not -path '*/node_modules/*' | xargs rm -rf"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "turbo": "^2.10.2",
    "typescript": "^5.7.0"
  }
}
