{
  "name": "arch-systems",
  "version": "1.5.1",
  "bundlesize": [
    {
      "path": "apps/portal/.next/static/chunks/*.js",
      "maxSize": "5.5 MB"
    },
    {
      "path": "apps/portal/.next/static/chunks/*.css",
      "maxSize": "120 kB"
    }
  ],
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@napi-rs/cli": "^3.0.0",
    "@playwright/test": "^1.60.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "bundlesize": "^0.18.2",
    "eslint": "^8.57.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^5.45.0",
    "lint-staged": "^17.0.7",
    "markdownlint-cli": "^0.49.0",
    "preflight": "^0.2.0",
    "prettier": "^3.4.2",
    "secretlint": "^13.0.2",
    "supabase": "^2.98.2",
    "syncpack": "^13.0.4",
    "turbo": "^2.10.2",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "overrides": {
    "handlebars": ">=4.7.9",
    "brace-expansion": ">=2.0.2",
    "minimatch": ">=9.0.7",
    "braces": ">=3.0.3",
    "glob": ">=10.5.0",
    "serialize-javascript": ">=7.0.3",
    "kysely": ">=0.28.17",
    "tmp": ">=0.2.6",
    "uuid": ">=11.1.1",
    "smol-toml": ">=1.3.1",
    "esbuild": ">=0.25.0",
    "@babel/runtime": ">=7.26.10",
    "js-yaml@^3.0.0": ">=3.14.2",
    "js-yaml@^4.0.0": ">=4.1.1"
  },
  "packageManager": "pnpm@9.15.9",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter portal dev",
    "analyze": "ANALYZE=true pnpm --filter portal build",
    "build": "pnpm --filter portal build && pnpm --filter api build",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "lint": "pnpm --filter portal lint && pnpm --filter api lint",
    "lint:root": "eslint . --max-warnings 0",
    "test": "pnpm --filter portal test && pnpm --filter api test",
    "test:e2e": "playwright test",
    "quality": "pnpm lint && pnpm type-check && pnpm test && pnpm audit:rls && pnpm knip",
    "type-check": "pnpm --filter portal type-check && pnpm --filter api type-check",
    "ui": "pnpm --filter @repo/ui ui",
    "audit:rls": "node tools/audit-rls.cjs",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "policy:gen": "node tools/policy-compiler.cjs"
  },
  "type": "module",
  "volta": {
    "node": "24.15.0",
    "pnpm": "9.15.9"
  },
  "pnpm": {
    "overrides": {
      "@univerjs/icons": "1.12.0"
    }
  }
}
