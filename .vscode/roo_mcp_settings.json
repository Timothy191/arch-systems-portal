{
  "mcpServers": {
    "preflight-mcp": {
      "command": "node",
      "args": [
        "tools/preflight-mcp/index.js"
      ]
    },
    "n8n-mcp": {
      "command": "node",
      "args": [
        "tools/n8n-mcp/index.js"
      ],
      "env": {
        "N8N_URL": "http://localhost:5678",
        "N8N_EMAIL": "${N8N_EMAIL}",
        "N8N_PASSWORD": "${N8N_PASSWORD}"
      }
    },
    "codebase-memory": {
      "command": "codebase-memory-mcp",
      "args": []
    },
    "repowise-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "tools/repowise",
        "repowise",
        "mcp",
        ".",
        "--transport",
        "stdio"
      ]
    },
    "sense-mcp": {
      "command": "tools/sense/bin/sense",
      "args": []
    },
    "memex-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "tools/memex",
        "memex",
        "serve"
      ],
      "env": {
        "NEO4J_URI": "${NEO4J_URI:-bolt://localhost:7687}",
        "NEO4J_USER": "${NEO4J_USER:-neo4j}",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "deepgraph-nextjs": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-code-graph@latest",
        "vercel/next.js"
      ]
    },
    "deepgraph-react": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-code-graph@latest",
        "facebook/react"
      ]
    },
    "deepgraph-typescript": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-code-graph@latest",
        "microsoft/TypeScript"
      ]
    },
    "github-official": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "redis": {
      "command": "uvx",
      "args": [
        "--from",
        "redis-mcp-server@latest",
        "redis-mcp-server"
      ],
      "env": {
        "REDIS_URL": "redis://localhost:6379"
      }
    },
    "trace-mcp": {
      "command": "/home/timothy/.trace-mcp/bin/trace-mcp",
      "args": [
        "serve"
      ]
    },
    "agentic-tools-mcp": {
      "command": "node",
      "args": [
        ".aistack/packages/agentic-tools-mcp/src/server.js"
      ],
      "description": "Project memory and task store"
    },
    "token-optimizer-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "token-optimizer-mcp"
      ]
    },
    "shadcn-ui-mcp-server": {
      "command": "npx",
      "args": ["-y", "shadcn-ui-mcp-server"],
      "description": "shadcn/ui component access and code generation"
    },
    "world-intel-mcp": {
      "command": "npx",
      "args": ["-y", "world-intel-mcp"],
      "description": "Real-time global intelligence across 30+ domains with 109 MCP tools"
    },
    "mcp-graphql-forge": {
      "command": "npx",
      "args": ["-y", "mcp-graphql-forge"],
      "description": "Configuration-driven MCP server exposing curated GraphQL queries as modular tools"
    },
    "memory-mcp": {
      "command": "npx",
      "args": ["-y", "memory-mcp"],
      "description": "Memory management and context window caching for LLM interactions"
    },
    "rn-debug-mcp": {
      "command": "npx",
      "args": ["-y", "rn-debug-mcp"],
      "description": "React Native debug — see, understand, and interact with RN apps on emulator/device"
    },
    "vscode-mcp-server": {
      "command": "npx",
      "args": ["-y", "vscode-mcp-server"],
      "description": "VS Code extension allowing MCP clients to interact with the editor"
    }
  }
}
