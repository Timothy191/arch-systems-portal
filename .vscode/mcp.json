{
  "servers": {
    "repowise": {
      "type": "stdio",
      "command": "repowise",
      "args": [
        "mcp",
        "/home/arch/Applications/Arch-Mk2",
        "--transport",
        "stdio"
      ],
      "description": "repowise: codebase intelligence \u2014 docs, graph, git signals, dead code, decisions"
    },
    "trace-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "trace-mcp@latest"
      ]
    },
    "agentic-tools-mcp": {
      "type": "stdio",
      "command": "node",
      "args": [
        ".aistack/packages/agentic-tools-mcp/src/server.js"
      ],
      "description": "Project memory and task store"
    }
  }
}
